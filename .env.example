# Supabase (required for app)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Demo mode: password for demo.client / demo.admin / demo.supplier (optional; omit to disable demo entry)
VITE_DEMO_PASSWORD=

# Optional: OTP length for email verification (defaults apply if unset)
# VITE_EMAIL_OTP_LENGTH=6

# SECURITY: Do NOT set service role key in the browser for production.
# It is used only for prototype/admin bypass; move privileged ops to Edge Functions.
# VITE_SUPABASE_SERVICE_ROLE_KEY=
